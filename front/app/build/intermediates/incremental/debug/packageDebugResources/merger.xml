нформационных целях.\n\n4. Условия оплаты\nНекоторые услуги могут быть платными. Цены указаны в приложении.\n\n5. Изменение условий\nМы оставляем за собой право изменять данные условия в любое время.</string><string name="submit_report">Отправить</string><string name="severity_major">Тяжёлая</string><string name="severity_moderate">Средняя</string><string name="take_photo">Сфотографировать</string><string name="accident_photo">Фото аварии</string><string name="choose_gallery">Из галереи</string><string name="accident_description_placeholder">Краткое описание аварии</string><string name="severity_minor">Лёгкая</string><string name="location_label">Местоположение</string><string name="location_placeholder">Ташкент, Чиланзарский район</string><string name="search_source">Источник поиска</string><string name="severity_label">Степень тяжести</string><string name="plate_search_placeholder">Введите гос. номер (напр., 01 A 123 AA)</string><string name="report_accident_desc">Сфотографируйте и введите гос. номер</string><string name="source_local">Наша база</string><string name="source_government">Гос. база</string><string name="report_accident">Сообщить об аварии</string><string name="source_internet">Интернет</string><string name="search_type_plate">Гос. номер</string><string name="search_type_vin">VIN код</string><string name="search_type_label">Тип поиска</string></file><file name="ic_launcher_foreground" path="C:\Users\jamsh\Desktop\AutoChecker\front\app\src\main\res\drawable\ic_launcher_foreground.xml" qualifiers="" type="drawable"/><file name="ic_launcher" path="C:\Users\jamsh\Desktop\AutoChecker\front\app\src\main\res\mipmap-anydpi-v26\ic_launcher.xml" qualifiers="anydpi-v26" type="mipmap"/><file name="ic_launcher_round" path="C:\Users\jamsh\Desktop\AutoChecker\front\app\src\main\res\mipmap-anydpi-v26\ic_launcher_round.xml" qualifiers="anydpi-v26" type="mipmap"/><file name="network_security_config" path="C:\Users\jamsh\Desktop\AutoChecker\front\app\src\main\res\xml\ne